// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
  previewFeatures = ["driverAdapters", "queryCompiler"]
}

generator json {
  provider = "prisma-json-types-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id      Int      @id @default(autoincrement())
  email   String   @unique
  name    String
  nickname String @unique
  password String?
  googleId String?
  role Role @default(USER)
  isWriter Boolean @default(false)
  /// Tag “Apoiador” (sem permissões extras por enquanto; só exibição / futuras funções)
  isSupporter Boolean @default(false)
  instagram String?
  avatarUrl String?
  ludopediaUrl String?
  birthday DateTime?
  favoriteGame String?
  favoriteEvent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tournamentPlayers TournamentPlayer[]
  createdSantoriniRooms SantoriniRoom[]
  santoriniRoomPlayers SantoriniRoomPlayer[]
  eventParticipants EventParticipant[]
  blogPosts BlogPost[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@index([token])
  @@index([userId])
}

model BlogPost {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId    Int

  @@index([slug])
  @@index([publishedAt])
}

enum Role {
  USER
  STAFF
  ADMIN
}

model Tournament {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  rounds       Round[]
  players      TournamentPlayer[]
  status       TournamentStatus  @default(REGISTRATION_OPEN)
  name         String
  desiredTableSize Int
  event        Event?
}

model Event {
  id           Int          @id @default(autoincrement())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  name         String
  description  String?
  date         DateTime?
  badgeFile    String?
  status       EventStatus  @default(ABERTO)
  type         EventType    @default(GENERAL)
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  tournamentId Int?         @unique
  participants EventParticipant[]
}

enum EventStatus {
  SECRETO   // Só ADMIN vê e edita
  ABERTO    // Inscrições abertas
  ENCERRADO // Inscrições encerradas
}

enum EventType {
  TOURNAMENT
  GENERAL
}

model EventParticipant {
  id          Int      @id @default(autoincrement())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId     Int
  user        User     @relation(fields: [userId], references: [id])
  userId      Int
  checkedInAt DateTime @default(now())
  /// Campeão destacado na página do evento (apenas eventos tipo GENERAL; vários permitidos)
  isChampion  Boolean  @default(false)
  /// Pódio do torneio: 1, 2 ou 3 — só eventos tipo TOURNAMENT; uma pessoa por posição por evento
  tournamentPlace Int?

  @@unique([eventId, userId])
  @@unique([eventId, tournamentPlace])
  @@index([eventId, userId])
}

enum TournamentStatus{
  REGISTRATION_OPEN
  OPEN_ROUND
  FINISHED_ROUND
  TOURNAMENT_FINISHED
}

model Round {
  id           Int        @id @default(autoincrement())
  roundNumber  Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId Int
  matches      Match[]
  status       RoundStatus  @default(ACTIVE)
}

enum RoundStatus{
  ACTIVE
  FINISHED
}

model Match {
  id            Int      @id @default(autoincrement())
  round         Round    @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId       Int
  players       TournamentPlayer[]
  matchResults  MatchResult[]
}

model TournamentPlayer {
  id                Int        @id @default(autoincrement())
  tournament        Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tournamentId      Int
  matches           Match[]
  matchResults      MatchResult[]
  user              User       @relation(fields: [userId], references: [id])
  userId            Int
  status            TournamentPlayerStatus  @default(ACTIVE)

  @@unique([tournamentId, userId])
  @@index([tournamentId, userId])
}

enum TournamentPlayerStatus{
  ACTIVE
  DROPPED
}

model MatchResult {
  id        Int     @id @default(autoincrement())
  player    TournamentPlayer  @relation(fields: [playerId], references: [id])
  playerId  Int
  match     Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchId   Int
  points    Float

  @@unique([playerId, matchId])
  @@index([playerId, matchId])
}

model Enigma {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  name      String
  slug      String        @unique
  published Boolean       @default(false)
  phases    EnigmaPhase[]
}

model EnigmaPhase {
  id        Int       @id @default(autoincrement())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  enigma    Enigma    @relation(fields: [enigmaId], references: [id], onDelete: Cascade)
  enigmaId  Int
  order     Int
  title     String
  pageTitle String?
  mediaType MediaType @default(NONE)
  mediaUrl  String?
  imageFile String?
  imageAlt  String?
  phrase    String
  answer    String
  tipPhrase String?
  /// Na jogada: cor igual ao fundo (visível ao selecionar / realçar)
  hiddenHint String?

  @@unique([enigmaId, order])
}

enum MediaType {
  NONE
  IMAGE
  VIDEO
  AUDIO
}

model SantoriniRoom {
  id Int @id @default(autoincrement())
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId Int
  roomCode String @unique
  status SantoriniRoomStatus @default(WAITING)
  /// [SantoriniGameState]
  gameState Json
  players SantoriniRoomPlayer[]

  @@index([roomCode])
}

enum SantoriniRoomStatus {
  WAITING
  PLAYING
  FINISHED
}

model SantoriniRoomPlayer {
  id Int @id @default(autoincrement())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  room SantoriniRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId Int
  winner Boolean @default(false)

  @@unique([roomId, userId])
  @@index([roomId, userId])
}